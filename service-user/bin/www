#!/usr/bin/env node

const app = require('../app');
const http = require('http');

const port = parseInt(process.env.PORT || '3001', 10);
app.set('port', port);

const server = http.createServer(app);

server.listen(port);
console.log('service-user berjalan di port ' + port);

server.on('error', (err) => {
  if (err.syscall !== 'listen') throw err;
  const bind = 'Port ' + port;
  if (err.code === 'EACCES') {
    console.error(bind + ' butuh hak akses lebih tinggi');
    process.exit(1);
  } else if (err.code === 'EADDRINUSE') {
    console.error(bind + ' sudah dipakai');
    process.exit(1);
  } else {
    throw err;
  }
});